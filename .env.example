# ─────────────────────────────────────────────────────────────────────────────
# FridgeRAG Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI API Key ────────────────────────────────────────────────────────────
# Required ONLY when USE_LLM_RERANKER=true
# Get your key at: https://platform.openai.com/api-keys
# New accounts get free credits. gpt-4o-mini costs ~$0.0001 per request.
# IMPORTANT: No quotes around the key. No spaces around the = sign.
# WRONG:  OPENAI_API_KEY="sk-proj-abc123"
# RIGHT:  OPENAI_API_KEY=sk-proj-abc123
OPENAI_API_KEY=your-openai-api-key-here

# ── Reranker Mode ─────────────────────────────────────────────────────────────
# Controls which reranker is used after ChromaDB retrieval.
#
# true  → GPT-4o-mini LLM reranker
#         - Best quality: reasons about ingredient coverage + nutrition
#         - Requires valid OPENAI_API_KEY with credits
#         - Speed: ~3 seconds per request
#         - Cost: ~$0.0001 per request
#
# false → Free local reranker (DEFAULT)
#         - Good quality: rule-based coverage + similarity scoring
#         - No API key needed, works completely offline
#         - Speed: instant
#         - Cost: free
#
# Restart uvicorn after changing this setting.
USE_LLM_RERANKER=false
