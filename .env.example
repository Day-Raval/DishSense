# ─────────────────────────────────────────────────────────────────────────────
# FridgeRAG Environment Configuration
# Copy this file to .env:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI API Key ────────────────────────────────────────────────────────────
# Required ONLY when USE_LLM_RERANKER=true
# Get your key at: https://platform.openai.com/api-keys
# IMPORTANT: No quotes. No spaces around =.
# WRONG:  OPENAI_API_KEY="sk-proj-abc123"
# RIGHT:  OPENAI_API_KEY=sk-proj-abc123
OPENAI_API_KEY=your-openai-api-key-here

# ── Reranker mode ─────────────────────────────────────────────────────────────
# true  → GPT-4o-mini LLM reranker (best quality, needs API key + credits)
# false → Free local reranker      (good quality, instant, no key needed)
# Restart uvicorn after changing this.
USE_LLM_RERANKER=false

# ── Compute profile ───────────────────────────────────────────────────────────
# auto      → auto-detect (GPU if CUDA available, else cpu_light)
# gpu_full  → NVIDIA GPU, largest models, best quality
# gpu_light → NVIDIA GPU, smaller models, faster inference
# cpu_full  → CPU only, medium models, slow but accurate
# cpu_light → CPU only, smallest models, fastest fallback (default)
# Restart uvicorn after changing this.
COMPUTE_PROFILE=auto